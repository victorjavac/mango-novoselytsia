// Firestore rules for the MANGO POS project (mangopos-393c4).
// Apply in Firebase Console -> Firestore Database -> Rules -> Publish.
// Cashier access now requires a non-anonymous Firebase Auth user whose
// users/{uid}.active field is true. Manage users from Firebase Console.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedInUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function activeUser() {
      return signedInUser()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    function validCode(code) {
      return code.size() > 0
        && code.size() <= 128
        && !code.matches('.*/.*')
        && code != '.'
        && code != '..'
        && !code.matches('^__.*__$');
    }

    function optionalText(data, field, maxLength) {
      return !(field in data)
        || (data[field] is string && data[field].size() <= maxLength);
    }

    function optionalBool(data, field) {
      return !(field in data) || data[field] is bool;
    }

    function validProduct(code, data) {
      return validCode(code)
        && data.keys().hasOnly(['name', 'brand', 'size', 'article', 'price', 'quantity', 'archived'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 200
        && optionalText(data, 'brand', 100)
        && optionalText(data, 'size', 50)
        && optionalText(data, 'article', 100)
        && optionalBool(data, 'archived')
        && data.price is number
        && data.price >= 0
        && data.price <= 1000000
        && data.quantity is number
        && data.quantity >= 0
        && data.quantity <= 1000000;
    }

    function validSale(data) {
      return data.keys().hasOnly(['ts', 'tsMillis', 'dateKey', 'total', 'subtotal', 'discount', 'itemCount', 'items'])
        && data.tsMillis is number
        && data.dateKey is string
        && data.dateKey.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.total is number
        && data.total >= 0
        && data.subtotal is number
        && data.subtotal >= 0
        && data.discount is number
        && data.discount >= 0
        && data.itemCount is number
        && data.itemCount > 0
        && data.itemCount <= 500
        && data.items is list
        && data.items.size() > 0
        && data.items.size() <= 100;
    }

    match /users/{uid} {
      allow read: if signedInUser() && request.auth.uid == uid;
      allow write: if false;
    }

    match /products/{code} {
      allow read: if activeUser();
      allow create, update: if activeUser() && validProduct(code, request.resource.data);
      allow delete: if activeUser() && validCode(code);
    }

    match /продукти/{code} {
      allow read: if activeUser();
      allow create, update: if activeUser() && validProduct(code, request.resource.data);
      allow delete: if activeUser() && validCode(code);
    }

    match /settings/{doc} {
      allow read, write: if activeUser();
    }

    match /sales/{doc} {
      allow read: if activeUser();
      allow create: if activeUser() && validSale(request.resource.data);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
